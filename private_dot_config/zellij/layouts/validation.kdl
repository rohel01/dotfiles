layout {
    cwd "/home/michael/proj"
    tab name="yamcs-dbc" focus=true hide_floating_panes=true {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        pane command="uv" cwd="pfgen/yamcs-explore/yamcs-python" focus=true {
            args "run" "hx" "."
            start_suspended false
        }
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="flatsat-lib" hide_floating_panes=true {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        pane command="uv" cwd="forge/flatsat-lib" {
            args "run" "hx" "."
            start_suspended false
        }
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="endurance-icd" hide_floating_panes=true {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        pane command="uv" cwd="pfgen/endurance-pl-obc-sw/validation/cases/endurance-db-icd" {
            args "run" "hx" "."
            start_suspended false
        }
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="yamcs" hide_floating_panes=true {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        pane command="mvn" cwd="pfgen/yamcs-explore/yamcs-quickstart"{
            args "yamcs:run"
            start_suspended true
        }
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    new_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        pane cwd="/home/michael/proj/pfgen/yamcs-explore"
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    swap_tiled_layout name="vertical" {
        tab max_panes=5 {
            pane size=1 borderless=true {
                plugin location="tab-bar"
            }
            pane {
                pane split_direction="vertical" {
                    pane
                    pane {
                        children
                    }
                }
            }
            pane size=1 borderless=true {
                plugin location="status-bar"
            }
        }
        tab max_panes=8 {
            pane size=1 borderless=true {
                plugin location="tab-bar"
            }
            pane {
                pane split_direction="vertical" {
                    pane {
                        children
                    }
                    pane {
                        pane
                        pane
                        pane
                        pane
                    }
                }
            }
            pane size=1 borderless=true {
                plugin location="status-bar"
            }
        }
        tab max_panes=12 {
            pane size=1 borderless=true {
                plugin location="tab-bar"
            }
            pane {
                pane split_direction="vertical" {
                    pane {
                        children
                    }
                    pane {
                        pane
                        pane
                        pane
                        pane
                    }
                    pane {
                        pane
                        pane
                        pane
                        pane
                    }
                }
            }
            pane size=1 borderless=true {
                plugin location="status-bar"
            }
        }
    }
    swap_tiled_layout name="horizontal" {
        tab max_panes=4 {
            pane size=1 borderless=true {
                plugin location="tab-bar"
            }
            pane {
                pane
                pane
            }
            pane size=1 borderless=true {
                plugin location="status-bar"
            }
        }
        tab max_panes=8 {
            pane size=1 borderless=true {
                plugin location="tab-bar"
            }
            pane {
                pane {
                    pane split_direction="vertical" {
                        children
                    }
                    pane split_direction="vertical" {
                        pane
                        pane
                        pane
                        pane
                    }
                }
            }
            pane size=1 borderless=true {
                plugin location="status-bar"
            }
        }
        tab max_panes=12 {
            pane size=1 borderless=true {
                plugin location="tab-bar"
            }
            pane {
                pane {
                    pane split_direction="vertical" {
                        children
                    }
                    pane split_direction="vertical" {
                        pane
                        pane
                        pane
                        pane
                    }
                    pane split_direction="vertical" {
                        pane
                        pane
                        pane
                        pane
                    }
                }
            }
            pane size=1 borderless=true {
                plugin location="status-bar"
            }
        }
    }
    swap_tiled_layout name="stacked" {
        tab min_panes=5 {
            pane size=1 borderless=true {
                plugin location="tab-bar"
            }
            pane {
                pane split_direction="vertical" {
                    pane
                    pane stacked=true {
                        children
                    }
                }
            }
            pane size=1 borderless=true {
                plugin location="status-bar"
            }
        }
    }
    swap_floating_layout name="staggered" {
        floating_panes {
        }
    }
    swap_floating_layout name="enlarged" {
        floating_panes max_panes=10 {
            pane cwd="/home/michael/proj" {
                height "90%"
                width "90%"
                x "5%"
                y 1
            }
            pane cwd="/home/michael/proj" {
                height "90%"
                width "90%"
                x "5%"
                y 2
            }
            pane cwd="/home/michael/proj" {
                height "90%"
                width "90%"
                x "5%"
                y 3
            }
            pane cwd="/home/michael/proj" {
                height "90%"
                width "90%"
                x "5%"
                y 4
            }
            pane cwd="/home/michael/proj" {
                height "90%"
                width "90%"
                x "5%"
                y 5
            }
            pane cwd="/home/michael/proj" {
                height "90%"
                width "90%"
                x "5%"
                y 6
            }
            pane cwd="/home/michael/proj" {
                height "90%"
                width "90%"
                x "5%"
                y 7
            }
            pane cwd="/home/michael/proj" {
                height "90%"
                width "90%"
                x "5%"
                y 8
            }
            pane cwd="/home/michael/proj" {
                height "90%"
                width "90%"
                x "5%"
                y 9
            }
            pane cwd="/home/michael/proj" {
                height "90%"
                width "90%"
                x 10
                y 10
            }
        }
    }
    swap_floating_layout name="spread" {
        floating_panes max_panes=1 {
            pane cwd="/home/michael/proj" {
                x "50%"
                y "50%"
            }
        }
        floating_panes max_panes=2 {
            pane cwd="/home/michael/proj" {
                width "45%"
                x "1%"
                y "25%"
            }
            pane cwd="/home/michael/proj" {
                width "45%"
                x "50%"
                y "25%"
            }
        }
        floating_panes max_panes=3 {
            pane cwd="/home/michael/proj" {
                height "45%"
                width "45%"
                y "55%"
            }
            pane cwd="/home/michael/proj" {
                width "45%"
                x "1%"
                y "1%"
            }
            pane cwd="/home/michael/proj" {
                width "45%"
                x "50%"
                y "1%"
            }
        }
        floating_panes max_panes=4 {
            pane cwd="/home/michael/proj" {
                height "45%"
                width "45%"
                x "1%"
                y "55%"
            }
            pane cwd="/home/michael/proj" {
                height "45%"
                width "45%"
                x "50%"
                y "55%"
            }
            pane cwd="/home/michael/proj" {
                height "45%"
                width "45%"
                x "1%"
                y "1%"
            }
            pane cwd="/home/michael/proj" {
                height "45%"
                width "45%"
                x "50%"
                y "1%"
            }
        }
    }
}
